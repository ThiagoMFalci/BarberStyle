@ApiBabterStyle_HostAddress = http://localhost:5216
@Token = cole-o-token-do-login-aqui

POST {{ApiBabterStyle_HostAddress}}/api/auth/cadastro
Content-Type: application/json

{
  "name": "Cliente Teste",
  "email": "cliente@barberstyle.com",
  "phone": "11999999999",
  "password": "123456"
}

###

POST {{ApiBabterStyle_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "cliente@barberstyle.com",
  "password": "123456"
}

###

GET {{ApiBabterStyle_HostAddress}}/api/barbeiros
Accept: application/json

###

GET {{ApiBabterStyle_HostAddress}}/api/servicos
Accept: application/json

###

POST {{ApiBabterStyle_HostAddress}}/api/agendamentos
